pipeline {
    agent {label 'docker' }
triggers {
        pollSCM('H/2 * * * *')   // every 2 minutes
    }

    stages {
        stage('Clone Repository') {
            steps {
                git branch: 'main',
                    url: 'git@github.com:Madhuri-java/TestDevOpsRepo.git',
                    credentialsId: 'github-cred'

            }
        }

        stage('Check the docker cli') {
      steps {
        sh "docker --version"
        sh "docker ps -a"
        sh "docker compose --version"
      }
    }

        stage('docker-build') {
            steps {
                echo "docker build step here..."
                sh "docker build . -t pythonapp:v1"
            }
        }

        stage('docker container creation') {
            steps {
                echo "Running Docker compose here..."
                sh "docker compose up -d"
            }
        }

        stage('Cheking output') {
            steps {
               sh "docker ps"
		sh "docker compose ps"
            }
        }

        stage('app working') {
            steps {
               sh "curl localhost:9010"
            }
        }
        stage('Image push') {
            steps {
               sh "aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin 195275631966.dkr.ecr.us-east-1.amazonaws.com"
               sh "docker tag pythonapp:latest 195275631966.dkr.ecr.us-east-1.amazonaws.com/pythonapp:latest"
               sh "docker push 195275631966.dkr.ecr.us-east-1.amazonaws.com/pythonapp:latest"
            }
        }
    }
}
